SETLIST_FM_API_SECRET="you need to set the Setlist FM API secret"
SPOTIFY_CLIENT_ID="you need to set the Spotify Client ID"
SPOTIFY_CLIENT_SECRET="you need to set the Spotify Client Secret"

# Grafana Cloud Configuration (Optional - for production observability)
# Get these values from your Grafana Cloud stack: https://grafana.com
GRAFANA_CLOUD_API_KEY="your Grafana Cloud API token with write access"
GRAFANA_CLOUD_INSTANCE_ID="your numeric instance ID (e.g., 123456)"
GRAFANA_CLOUD_USER_ID="your Tempo auth user ID (from Tempo data source config)"
GRAFANA_CLOUD_REGION="your stack region (e.g., us-central1, eu-west-1)"
GRAFANA_CLOUD_ZONE="optional zone identifier (e.g., prod-us-central-0)"
