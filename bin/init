#!/usr/bin/env bash

# script/init: Initalize a local development environment for working on the
#               application.

YELLOW='\033[1;33m'
NC='\033[0m' # No Color
ENV_FILE_CREATED=false

cd "$(dirname "$0")/.."

if ! [ -f .env ]; then
    echo "==> Copying .env file…"
    cp -n .env.example .env
    ENV_FILE_CREATED=true
fi

bin/setup

if $ENV_FILE_CREATED; then
    echo -e "${YELLOW}\n====================="
    echo -e ".env file created as a part of project initalization.\n"
    echo "You will need to update it with real secrets."
    echo -e "=====================\n${NC}"
fi
