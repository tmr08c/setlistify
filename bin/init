#!/usr/bin/env bash

# script/init: Initalize a local development environment for working on the
#               application.

set -e

cd "$(dirname "$0")/.."

if ! [ -f .env ]; then
    echo "==> Copying .env file…"
    cp -n .env.example .env
fi

bin/setup

echo -e "\n====================="
echo -e "Project setup complete!\n"
echo "NOTE: You will need to update .env with real secrets."
echo -e "=====================\n"
