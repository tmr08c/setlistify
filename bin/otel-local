#!/bin/bash

# Script to manage local OpenTelemetry stack

# Function to check if Docker is running
check_docker() {
  if ! command -v docker &> /dev/null; then
    echo "❌ Docker is not installed!"
    echo ""
    echo "Please install Docker Desktop from: https://www.docker.com/products/docker-desktop"
    echo "Or use your package manager:"
    echo "  - macOS: brew install --cask docker"
    echo "  - Ubuntu: sudo apt install docker.io docker-compose"
    echo ""
    exit 1
  fi
  
  if ! docker info &> /dev/null; then
    echo "❌ Docker is not running!"
    echo ""
    echo "Please start Docker Desktop or the Docker daemon."
    echo "On macOS: Open Docker Desktop from Applications"
    echo "On Linux: sudo systemctl start docker"
    echo ""
    exit 1
  fi
}

# Function to check if Docker Compose is available
check_docker_compose() {
  if ! command -v docker-compose &> /dev/null; then
    # Check if docker compose (v2) is available
    if ! docker compose version &> /dev/null; then
      echo "❌ Docker Compose is not installed!"
      echo ""
      echo "Please install Docker Compose:"
      echo "  - macOS: It comes with Docker Desktop"
      echo "  - Linux: sudo apt install docker-compose"
      echo ""
      exit 1
    else
      # Use docker compose (v2) syntax
      COMPOSE_CMD="docker compose"
    fi
  else
    # Use docker-compose (v1) syntax
    COMPOSE_CMD="docker-compose"
  fi
}

# Check prerequisites for all commands except help
if [ "${1:-start}" != "help" ]; then
  check_docker
  check_docker_compose
fi

case "${1:-start}" in
  start)
    echo "✅ Docker is running!"
    echo "Starting OpenTelemetry local stack..."
    $COMPOSE_CMD up -d
    echo "Waiting for services to be ready..."
    sleep 5
    echo ""
    echo "🚀 OpenTelemetry stack is running:"
    echo "  - Grafana UI: http://localhost:3000"
    echo "  - Tempo: http://localhost:3200"
    echo "  - Loki: http://localhost:3100"
    echo "  - Prometheus: http://localhost:9090"
    echo ""
    echo "To stop the stack, run: ./bin/otel-local stop"
    ;;
  stop)
    echo "Stopping OpenTelemetry local stack..."
    $COMPOSE_CMD down
    echo "✅ Stack stopped successfully"
    ;;
  logs)
    $COMPOSE_CMD logs -f
    ;;
  status)
    $COMPOSE_CMD ps
    ;;
  reset)
    echo "Resetting OpenTelemetry local stack (removing volumes)..."
    $COMPOSE_CMD down -v
    rm -rf docker/tempo-data docker/loki-data docker/prometheus-data
    echo "✅ Stack reset complete"
    ;;
  help|--help|-h)
    echo "OpenTelemetry Local Development Stack Manager"
    echo ""
    echo "Usage: ./bin/otel-local {start|stop|logs|status|reset|help}"
    echo ""
    echo "Commands:"
    echo "  start  - Start the OpenTelemetry stack (default)"
    echo "  stop   - Stop the OpenTelemetry stack"
    echo "  logs   - Follow logs from all services"
    echo "  status - Show status of all services"
    echo "  reset  - Stop stack and remove all data volumes"
    echo "  help   - Show this help message"
    echo ""
    echo "Requirements:"
    echo "  - Docker Desktop or Docker Engine"
    echo "  - Docker Compose"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Usage: ./bin/otel-local {start|stop|logs|status|reset|help}"
    exit 1
    ;;
esac